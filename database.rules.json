{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        "semesters": {
          "$semesterId": {
            ".validate": "newData.hasChildren(['name', 'gpa', 'courses', 'date'])"
          }
        },
        "history": {
          "$historyId": {
            ".validate": "newData.hasChildren(['name', 'gpa', 'courses', 'date'])"
          }
        }
      }
    }
  }
}
